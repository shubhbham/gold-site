---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import PriceWidget from "../components/PriceWidget";
import PriceChart from "../components/PriceChart";
import GoldInvestCTA from "../components/GoldInvestCTA";
import AdSlot from "../components/AdSlot";
import {
  CITY_PATHS,
  FAQS,
  cityDescription,
  currentMonthYear,
  formatCurrencyValue,
  formatPriceDate,
  getCanonicalUrl,
  getCityConfig,
  getCityLatestData,
  getDefaultKarat,
  getHistoryData,
} from "../lib/site";

export function getStaticPaths() {
  return CITY_PATHS.map((city) => ({ params: { city } }));
}

const { city } = Astro.params;
const citySlug = city ?? "bangalore";
const cityConfig = getCityConfig(citySlug);
const entries = await getCityLatestData(citySlug);
const defaultKarat = getDefaultKarat(citySlug);
const heroData = entries.find((entry) => entry.karat === defaultKarat) ?? entries[0] ?? null;
const chartData = await getHistoryData(citySlug, defaultKarat, "1m");
const historyRows = chartData.slice(-10).reverse();

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: getCanonicalUrl("/") },
    { "@type": "ListItem", position: 2, name: cityConfig?.city_name ?? citySlug, item: getCanonicalUrl(`/gold-price-today-${citySlug}`) },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: FAQS.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: { "@type": "Answer", text: item.answer },
  })),
};
---

<BaseLayout
  title={`Gold Price Today in ${cityConfig?.city_name ?? citySlug} | 22k & 24k Rate – ${currentMonthYear()}`}
  description={`Track today’s 22k and 24k gold rate in ${cityConfig?.city_name ?? citySlug} with history, calculator support, and benchmark comparison data.`}
  canonical={getCanonicalUrl(`/gold-price-today-${citySlug}`)}
  schema={breadcrumbSchema}
>
  <section class="mx-auto max-w-7xl px-4 py-10 md:px-6">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,2fr)_320px]">
      <div class="space-y-8">
        <PriceWidget client:load initialData={heroData} defaultCity={citySlug} defaultKarat={defaultKarat} />

        <section class="rounded-4xl border border-gray-200 bg-white p-6 shadow-[0_24px_80px_-44px_rgba(17,24,39,0.3)]">
          <div class="flex flex-wrap gap-3">
            {[22, 24].map((karat) => (
              <span class={`rounded-full px-4 py-2 text-sm font-semibold ${defaultKarat === karat ? "bg-amber-600 text-white" : "bg-gray-100 text-gray-600"}`}>
                {karat}k
              </span>
            ))}
          </div>
          <div class="mt-6">
            <PriceChart client:only="react" city={citySlug} karat={defaultKarat} initialRange="1m" initialData={chartData} />
          </div>
        </section>

        <AdSlot slot="in-article" />

        <section class="rounded-4xl border border-gray-200 bg-white p-6 shadow-[0_24px_80px_-44px_rgba(17,24,39,0.3)]">
          <h2 class="text-2xl font-semibold text-gray-950">Last 10 days benchmark table</h2>
          <div class="mt-6 overflow-x-auto">
            <table class="min-w-full text-left text-sm">
              <thead>
                <tr class="border-b border-gray-200 text-gray-500">
                  <th class="px-3 py-3">Date</th>
                  <th class="px-3 py-3">22k</th>
                  <th class="px-3 py-3">24k</th>
                  <th class="px-3 py-3">Change %</th>
                </tr>
              </thead>
              <tbody>
                {historyRows.map((row) => {
                  const twentyTwo = entries.find((entry) => entry.karat === 22);
                  const twentyFour = entries.find((entry) => entry.karat === 24);
                  return (
                    <tr class="border-b border-gray-100">
                      <td class="px-3 py-3 text-gray-600">{formatPriceDate(row.price_date)}</td>
                      <td class="px-3 py-3 font-medium text-gray-950">{twentyTwo ? formatCurrencyValue(twentyTwo.price_local, twentyTwo.currency) : "-"}</td>
                      <td class="px-3 py-3 font-medium text-gray-950">{twentyFour ? formatCurrencyValue(twentyFour.price_local, twentyFour.currency) : "-"}</td>
                      <td class="px-3 py-3 text-gray-600">{row.change_percent}%</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </section>

        <GoldInvestCTA client:load countryCode={cityConfig?.country_code ?? "IN"} />

        <section class="rounded-4xl border border-gray-200 bg-white p-6 shadow-[0_24px_80px_-44px_rgba(17,24,39,0.3)]">
          <h2 class="text-2xl font-semibold text-gray-950">About gold prices in {cityConfig?.city_name ?? citySlug}</h2>
          <p class="mt-4 text-base leading-8 text-gray-600">{cityDescription(citySlug)}</p>
        </section>

        <section class="rounded-4xl border border-gray-200 bg-white p-6 shadow-[0_24px_80px_-44px_rgba(17,24,39,0.3)]">
          <h2 class="text-2xl font-semibold text-gray-950">FAQ</h2>
          <div class="mt-6 grid gap-4 md:grid-cols-2">
            {FAQS.map((item) => (
              <article class="rounded-3xl bg-amber-50/60 p-5">
                <h3 class="text-lg font-semibold text-gray-950">{item.question}</h3>
                <p class="mt-3 text-sm leading-7 text-gray-600">{item.answer}</p>
              </article>
            ))}
          </div>
        </section>
      </div>

      <aside>
        <AdSlot slot="sidebar" />
      </aside>
    </div>
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema).replace(/</g, "\\u003c")} />
  </section>
</BaseLayout>