---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import PriceChart from "../../components/PriceChart";
import {
  formatCurrencyValue,
  formatPriceDate,
  getCanonicalUrl,
  getCityConfig,
  getDefaultKarat,
  getHistoryData,
} from "../../lib/site";

const { city } = Astro.params;
const citySlug = city ?? "bangalore";
const cityConfig = getCityConfig(citySlug);
const karat = getDefaultKarat(citySlug);
const initialData = await getHistoryData(citySlug, karat, "1y");
---

<BaseLayout
  title={`Gold Price History ${cityConfig?.city_name ?? citySlug} | 5-Year Chart & Monthly Averages`}
  description={`Explore long-range gold price history for ${cityConfig?.city_name ?? citySlug} with a chart and monthly averages.`}
  canonical={getCanonicalUrl(`/gold-price-history/${citySlug}`)}
>
  <section class="mx-auto max-w-6xl px-4 py-12 md:px-6">
    <div class="mb-8 max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-700">History</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-gray-950">Gold price history for {cityConfig?.city_name ?? citySlug}</h1>
      <p class="mt-4 text-base leading-8 text-gray-600">
        Switch between 1 month and 5 years to see how the benchmark moved. The API now adapts granularity by range so longer windows stay readable without pagination.
      </p>
    </div>

    <PriceChart client:only="react" city={citySlug} karat={karat} initialRange="1y" initialData={initialData} />

    <section class="mt-10 rounded-4xl border border-gray-200 bg-white p-6 shadow-[0_24px_80px_-44px_rgba(17,24,39,0.3)]">
      <h2 class="text-2xl font-semibold text-gray-950">Recent history points</h2>
      <div class="mt-6 overflow-x-auto">
        <table class="min-w-full text-left text-sm">
          <thead>
            <tr class="border-b border-gray-200 text-gray-500">
              <th class="px-3 py-3">Month</th>
              <th class="px-3 py-3">Average price</th>
              <th class="px-3 py-3">Average USD</th>
              <th class="px-3 py-3">Change %</th>
            </tr>
          </thead>
          <tbody>
            {initialData.slice().reverse().map((row) => (
              <tr class="border-b border-gray-100">
                <td class="px-3 py-3 text-gray-600">{formatPriceDate(row.price_date)}</td>
                <td class="px-3 py-3 font-medium text-gray-950">{formatCurrencyValue(row.price_local, cityConfig?.currency ?? "INR")}</td>
                <td class="px-3 py-3 text-gray-600">{formatCurrencyValue(row.price_usd, "USD")}</td>
                <td class="px-3 py-3 text-gray-600">{row.change_percent}%</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </section>
</BaseLayout>