---
export const prerender = false;

import type { GoldPriceEntry } from "@gold-site/shared";
import { fetchJson } from "../lib/site";

const city = Astro.url.searchParams.get("city") ?? "bangalore";
const karat = Astro.url.searchParams.get("karat") ?? "22";
const theme = Astro.url.searchParams.get("theme") ?? "light";
const entry = await fetchJson<GoldPriceEntry>(`/api/gold?city=${city}&karat=${karat}`);
const isDark = theme === "dark";
const bodyBackground = isDark ? "#111827" : "#fffdf5";
const bodyColor = isDark ? "#f9fafb" : "#111827";
const cardBorder = isDark ? "rgba(255,255,255,.1)" : "#fcd34d";
const cardBackground = isDark ? "#1f2937" : "#ffffff";
const eyebrowColor = isDark ? "#fbbf24" : "#b45309";
const pillBackground = isDark ? "rgba(245,158,11,.12)" : "#fff7ed";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Gold Widget</title>
    <style define:vars={{ bodyBackground, bodyColor, cardBorder, cardBackground, eyebrowColor, pillBackground }}>
      body{margin:0;font-family:system-ui,-apple-system,sans-serif;background:var(--bodyBackground);color:var(--bodyColor)}
      .card{padding:16px;border-radius:18px;border:1px solid var(--cardBorder);background:var(--cardBackground)}
      .eyebrow{font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--eyebrowColor)}
      .city{font-size:20px;font-weight:700;margin-top:6px}
      .price{font-size:32px;font-weight:800;margin-top:12px}
      .meta{font-size:13px;opacity:.75;margin-top:8px}
      .pill{display:inline-block;margin-top:12px;padding:6px 10px;border-radius:999px;background:var(--pillBackground);font-size:12px;font-weight:700}
    </style>
  </head>
  <body>
    <div class="card">
      <div class="eyebrow">Live widget</div>
      <div class="city">{entry?.city_name ?? city}</div>
      <div class="price">{entry?.retail_local ?? entry?.price_local ?? "-"}</div>
      <div class="meta">{karat}k estimated retail for {entry?.price_date ?? "today"}</div>
      {entry?.benchmark_local ? <div class="meta">Benchmark: {entry.benchmark_local}</div> : null}
      <div class="pill">{entry?.currency ?? "INR"} • {entry?.unit ?? "10g"}</div>
    </div>
  </body>
</html>